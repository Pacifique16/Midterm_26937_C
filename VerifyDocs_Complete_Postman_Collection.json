{
  "info": {
    "name": "VerifyDocs API - Complete Collection",
    "_postman_id": "verifydocs-api-collection",
    "description": "Complete API collection for VerifyDocs system with all endpoints configured",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Province APIs (Location)",
      "item": [
        {
          "name": "Create Province (Save Location)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"code\": \"SOU\",\n    \"name\": \"Southern\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/provinces",
              "host": ["{{baseUrl}}"],
              "path": ["api", "provinces"]
            },
            "description": "Creates a new province (Location Saving - Rubric #2)"
          },
          "response": []
        },
        {
          "name": "Get All Provinces",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/provinces",
              "host": ["{{baseUrl}}"],
              "path": ["api", "provinces"]
            },
            "description": "Retrieves all provinces"
          },
          "response": []
        },
        {
          "name": "Get Province by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/provinces/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "provinces", "1"]
            },
            "description": "Get a specific province by ID"
          },
          "response": []
        },
        {
          "name": "Get Province by Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/provinces/code/KGL",
              "host": ["{{baseUrl}}"],
              "path": ["api", "provinces", "code", "KGL"]
            },
            "description": "Get province by code"
          },
          "response": []
        },
        {
          "name": "Check Province Exists (existBy)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/provinces/exists/KGL",
              "host": ["{{baseUrl}}"],
              "path": ["api", "provinces", "exists", "KGL"]
            },
            "description": "Check if province exists using existBy method (Rubric #7)"
          },
          "response": []
        }
      ]
    },
    {
