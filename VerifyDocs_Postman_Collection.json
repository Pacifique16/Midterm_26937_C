{
  "info": {
    "name": "VerifyDocs API Collection",
    "description": "Complete API collection for testing VerifyDocs system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Province APIs",
      "item": [
        {
          "name": "Create Province (Save Location)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"code\": \"KGL\",\n    \"name\": \"Kigali\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/provinces"}
          }
        },
        {
          "name": "Get All Provinces",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/provinces"}
          }
        },
        {
          "name": "Check Province Exists (existBy)",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/provinces/exists/KGL"}
          }
        }
      ]
    },
    {
      "name": "2. Institution APIs",
      "item": [
        {
          "name": "Create Institution",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"AUCA\",\n    \"email\": \"info@auca.ac.rw\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/institutions?provinceCode=KGL"}
          }
        },
        {
          "name": "Create Institution Profile (One-to-One)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"address\": \"KG 544 St\",\n    \"phone\": \"+250788123456\",\n    \"website\": \"www.auca.ac.rw\",\n    \"description\": \"Adventist University of Central Africa\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/institutions/1/profile"}
          }
        },
        {
          "name": "Get All Institutions",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/institutions"}
          }
        }
      ]
    },
    {
      "name": "3. User APIs",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user@auca.ac.rw\",\n    \"password\": \"password123\",\n    \"role\": \"ADMIN\",\n    \"fullName\": \"John Doe\",\n    \"institution\": {\"id\": 1}\n}"
            },
            "url": {"raw": "http://localhost:8080/api/users"}
          }
        },
        {
          "name": "Get Users with Pagination",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/users/paginated?page=0&size=10"}
          }
        },
        {
          "name": "Get Users with Sorting",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/users/sorted?sortBy=email"}
          }
        },
        {
          "name": "Get Users Paginated and Sorted",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/users/paginated-sorted?page=0&size=10&sortBy=fullName"}
          }
        },
        {
          "name": "Get Users by Province Code",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/users/province/code/KGL"}
          }
        },
        {
          "name": "Get Users by Province Name",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/users/province/name/Kigali"}
          }
        }
      ]
    },
    {
      "name": "4. Document APIs",
      "item": [
        {
          "name": "Create Document",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Bachelor Degree Certificate\",\n    \"filePath\": \"/uploads/cert123.pdf\",\n    \"hashValue\": \"abc123hash\",\n    \"institution\": {\"id\": 1}\n}"
            },
            "url": {"raw": "http://localhost:8080/api/documents"}
          }
        },
        {
          "name": "Get Documents with Pagination",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/documents/paginated?page=0&size=10"}
          }
        },
        {
          "name": "Get Documents with Sorting",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/documents/sorted?sortBy=issueDate"}
          }
        },
        {
          "name": "Verify Document",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/documents/verify/ABC12345?ipAddress=192.168.1.1"}
          }
        }
      ]
    }
  ]
}
